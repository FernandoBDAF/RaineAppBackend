rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================================================
    // Helper Functions
    // ========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isConnectionMember(connectionId) {
      return request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.memberUids;
    }
    
    function enforcePaginationLimit(maxLimit) {
      return request.query.limit <= maxLimit;
    }
    
    // ========================================================================
    // Users Collection
    // ========================================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow update: if isOwner(userId) 
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['subscriptionStatus', 'subscriptionPlan', 'subscriptionStartedAt', 
                     'subscriptionUpdatedAt', 'subscriptionCancelledAt', 'subscriptionExpiredAt',
                     'suspended', 'suspendedAt', 'suspendReason', 'role']);
      
      allow create, delete: if false;
      
      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ========================================================================
    // Notifications Collection
    // ========================================================================
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      
      allow create, delete: if false;
    }
    
    // ========================================================================
    // User Reports Collection (for moderation)
    // ========================================================================
    
    match /userReports/{reportId} {
      allow create: if isAuthenticated() 
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending';
      
      allow read, update, delete: if false;
    }
    
    // ========================================================================
    // System Collections (Cloud Functions only)
    // ========================================================================
    
    match /rateLimits/{recordId} {
      allow read, write: if false;
    }
    
    match /processedEvents/{eventId} {
      allow read, write: if false;
    }
    
    match /processedWebhooks/{webhookId} {
      allow read, write: if false;
    }
    
    match /notificationRetryQueue/{itemId} {
      allow read, write: if false;
    }
    
    match /deadLetterQueue/{itemId} {
      allow read, write: if false;
    }

    // ========================================================================
    // Introductions Collection (curated suggestions, backoffice creates)
    // ========================================================================

    match /introductions/{introId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.userUids;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.userUids;
      allow create, delete: if false;
    }

    // ========================================================================
    // Connections Collection (per-relationship; connection IS the chat room)
    // ========================================================================

    match /connections/{connectionId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.memberUids;
      allow create: if isAuthenticated()
        && request.resource.data.fromUser.uid == request.auth.uid;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.memberUids;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && isConnectionMember(connectionId)
          && (request.query == null || enforcePaginationLimit(50));
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && isConnectionMember(connectionId)
          && get(/databases/$(database)/documents/connections/$(connectionId)).data.status == 'active';
        allow update: if isAuthenticated()
          && isConnectionMember(connectionId)
          && (
            resource.data.senderId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          );
        allow delete: if false;

        match /readBy/{readerId} {
          allow read: if isAuthenticated() && isConnectionMember(connectionId);
          allow write: if isOwner(readerId) && isConnectionMember(connectionId);
        }
      }

      match /typing/{userId} {
        allow read: if isAuthenticated() && isConnectionMember(connectionId);
        allow write: if isOwner(userId) && isConnectionMember(connectionId);
      }
    }
  }
}
